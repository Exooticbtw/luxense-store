<section class="luxense-bundles" id="luxense-bundles">
  <div class="luxense-wrap">
    <div class="luxense-head luxense-bundles__head">
      <div>
        <p class="luxense-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.title }}</h2>
      </div>
      {% if section.settings.cta_label != blank %}
        <a class="luxense-btn luxense-btn--solid" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>

    <div class="luxense-grid luxense-bundles__grid">
      {% for block in section.blocks %}
        <article class="luxense-card luxense-bundles__card {% if block.settings.featured %}is-featured{% endif %}" {{ block.shopify_attributes }}>
          <div class="luxense-bundles__top">
            <div>
              <p>{{ block.settings.badge }}</p>
              <h3>{{ block.settings.label }} <span>- {{ block.settings.savings }}</span></h3>
            </div>
            <div class="luxense-bundles__chip">{{ block.settings.savings }}</div>
          </div>
          <div class="luxense-bundles__price">{{ block.settings.price }}</div>
          <div class="luxense-bundles__compare">{{ block.settings.compare_at }}</div>
          <p class="luxense-bundles__caption">{{ block.settings.caption }}</p>
        <a class="luxense-btn {% if block.settings.featured %}luxense-btn--ghost{% else %}luxense-btn--solid{% endif %}" href="{{ block.settings.link | default: '#' }}">{{ block.settings.button_label }}</a>
        </article>
      {% endfor %}
    </div>

    <p class="luxense-bundles__trust">{{ section.settings.trust_text }}</p>
  </div>

  <style>
    .luxense-bundles { padding:86px 24px; background:var(--sec); }
    .luxense-wrap { max-width:1560px; margin:0 auto; }
    .luxense-head { max-width:700px; }
    .luxense-bundles__head { display:flex; justify-content:space-between; gap:24px; align-items:flex-end; flex-wrap:wrap; }
    .luxense-head h2 { font-family:'Manrope','Inter',system-ui,sans-serif; font-size:64px; line-height:1.02; letter-spacing:-.04em; margin:0; }
    .luxense-eyebrow { font-size:12px; text-transform:uppercase; letter-spacing:.24em; color:var(--accent); margin:0 0 10px; }
    .luxense-grid { display:grid; gap:16px; }
    .luxense-bundles__grid { grid-template-columns: repeat(3, minmax(0,1fr)); margin-top:38px; }
    .luxense-card { border-radius: 28px; border:1px solid rgba(17,17,17,.08); background:rgba(255,255,255,.86); box-shadow:0 22px 60px rgba(17,17,17,.08); }
    .luxense-bundles__card { padding:24px; }
    .luxense-bundles__card.is-featured { background:#111111; color:#ffffff; border-color: rgba(17,17,17,.92); box-shadow:0 22px 44px rgba(17,17,17,.14); }
    .luxense-bundles__top { display:flex; justify-content:space-between; gap:12px; align-items:flex-start; }
    .luxense-bundles__top p { font-size:13px; text-transform:uppercase; letter-spacing:.16em; margin:0; color:var(--muted); }
    .luxense-bundles__card.is-featured .luxense-bundles__top p { color: rgba(255,255,255,.66); }
    .luxense-bundles__top h3 { margin:10px 0 0; font-size:26px; line-height:1.08; font-weight:800; }
    .luxense-bundles__top h3 span { font-weight:700; color:var(--muted); }
    .luxense-bundles__card.is-featured .luxense-bundles__top h3 span { color: rgba(255,255,255,.78); }
    .luxense-bundles__chip { border-radius:999px; padding:7px 12px; background:rgba(200,169,106,.12); font-size:13px; font-weight:800; white-space:nowrap; }
    .luxense-bundles__card.is-featured .luxense-bundles__chip { background:rgba(255,255,255,.1); }
    .luxense-bundles__price { margin-top:22px; font-family:'Manrope','Inter',system-ui,sans-serif; font-size:46px; line-height:1; font-weight:600; }
    .luxense-bundles__compare { margin-top:6px; font-size:18px; text-decoration:line-through; color:var(--muted); }
    .luxense-bundles__card.is-featured .luxense-bundles__compare { color: rgba(255,255,255,.66); }
    .luxense-bundles__caption { margin:12px 0 0; font-size:15px; line-height:1.7; color:var(--muted); }
    .luxense-bundles__card.is-featured .luxense-bundles__caption { color: rgba(255,255,255,.76); }
    .luxense-bundles__card .luxense-btn { margin-top:24px; width:100%; }
    .luxense-bundles__trust { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-top:18px; color:var(--muted); font-size:14px; }
    @media (max-width: 1040px) { .luxense-bundles__grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
    @media (max-width: 760px) {
      .luxense-bundles { padding:64px 16px; }
      .luxense-head h2 { font-size:40px; }
      .luxense-bundles__grid { grid-template-columns:1fr; margin-top:28px; gap:14px; }
      .luxense-bundles__card { padding:20px; border-radius:24px; }
      .luxense-bundles__top h3 { font-size:24px; }
      .luxense-bundles__price { font-size:40px; }
      .luxense-bundles__card .luxense-btn { min-height:60px; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Luxense bundle offers",
  "tag": "section",
  "class": "luxense-bundle-offers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bundle offers" },
    { "type": "textarea", "id": "title", "label": "Title", "default": "The cleanest way to light more than one space." },
    { "type": "text", "id": "cta_label", "label": "Top CTA label", "default": "Shop MotionGlow" },
    { "type": "url", "id": "cta_link", "label": "Top CTA link" },
    { "type": "text", "id": "trust_text", "label": "Trust text", "default": "Free shipping, secure checkout, and a 30-day guarantee are included with every bundle." }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "Most Popular" },
        { "type": "checkbox", "id": "featured", "label": "Featured card", "default": false },
        { "type": "text", "id": "label", "label": "Label", "default": "Buy 2" },
        { "type": "text", "id": "savings", "label": "Savings", "default": "Save 15%" },
        { "type": "text", "id": "price", "label": "Price", "default": "$49.99" },
        { "type": "text", "id": "compare_at", "label": "Compare at price", "default": "$79.98" },
        { "type": "textarea", "id": "caption", "label": "Caption", "default": "Great for pairing a bedroom with a closet or corridor." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Select bundle" },
        { "type": "url", "id": "link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxense bundle offers",
      "blocks": [
        { "type": "bundle", "settings": { "badge": "Best for one room", "featured": false, "label": "Buy 1", "savings": "Save 0%", "price": "$29.99", "compare_at": "$39.99", "caption": "Try MotionGlow in a closet, nightstand, or hallway.", "button_label": "Select bundle" } },
        { "type": "bundle", "settings": { "badge": "Most Popular", "featured": true, "label": "Buy 2", "savings": "Save 15%", "price": "$49.99", "compare_at": "$79.98", "caption": "Great for pairing a bedroom with a closet or corridor.", "button_label": "Select bundle" } },
        { "type": "bundle", "settings": { "badge": "Best Value", "featured": false, "label": "Buy 4", "savings": "Save 25%", "price": "$89.99", "compare_at": "$159.96", "caption": "Cover the full path through your home in one order.", "button_label": "Select bundle" } }
      ]
    }
  ]
}
{% endschema %}
