{% liquid
  assign luxense_messages = section.blocks
%}

<section class="luxense-announcement" aria-label="Trust announcement bar">
  <div class="luxense-announcement__track">
    {% for block in luxense_messages %}
      <span class="luxense-announcement__item" {{ block.shopify_attributes }}>
        {{ block.settings.text | escape }}
      </span>
    {% endfor %}
    {% for block in luxense_messages %}
      <span class="luxense-announcement__item" aria-hidden="true">
        {{ block.settings.text | escape }}
      </span>
    {% endfor %}
    {% for block in luxense_messages %}
      <span class="luxense-announcement__item" aria-hidden="true">
        {{ block.settings.text | escape }}
      </span>
    {% endfor %}
  </div>

  <style>
    .luxense-announcement {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 110;
      overflow: hidden;
      background: #111111;
      color: rgba(255,255,255,.9);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .luxense-announcement__track {
      width: max-content;
      display: flex;
      align-items: center;
      gap: 32px;
      padding: 6px 14px;
      min-height: 32px;
      animation: luxenseAnnouncementMarquee 24s linear infinite;
      white-space: nowrap;
      mask-image: linear-gradient(90deg, transparent 0, black 8%, black 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(90deg, transparent 0, black 8%, black 92%, transparent 100%);
    }
    .luxense-announcement__item {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
    }
    @keyframes luxenseAnnouncementMarquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    @media (max-width: 760px) {
      .luxense-announcement__track {
        gap: 18px;
        padding: 5px 10px;
        min-height: 28px;
      }
      .luxense-announcement__item {
        font-size: 10px;
        letter-spacing: .12em;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Luxense announcement bar",
  "tag": "section",
  "class": "luxense-announcement-bar",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping over $35"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxense announcement bar",
      "blocks": [
        { "type": "message" },
        { "type": "message", "settings": { "text": "Secure checkout" } },
        { "type": "message", "settings": { "text": "30-day money-back guarantee" } },
        { "type": "message", "settings": { "text": "Fast human support" } }
      ]
    }
  ]
}
{% endschema %}
