<header class="luxense-navbar" id="luxense-navbar">
  <div class="luxense-navbar__inner">
    <details class="luxense-navbar__menu">
      <summary aria-label="Menu">&#9776;</summary>
      <nav aria-label="Mobile navigation">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link | default: '#' }}">{{ block.settings.label }}</a>
        {% endfor %}
      </nav>
    </details>

    <nav class="luxense-navbar__links" aria-label="Primary navigation">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}">{{ block.settings.label }}</a>
      {% endfor %}
    </nav>

    <a class="luxense-navbar__brand" href="{{ routes.root_url }}">
      <span>{{ section.settings.logo_text }}</span>
    </a>

    <a class="luxense-navbar__cart" href="{{ section.settings.cart_link | default: routes.cart_url }}" aria-label="Cart">
      <span>&#128722;</span>
    </a>
  </div>

  <style>
    .luxense-navbar {
      position: fixed;
      top: 32px;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(252,250,247,.94);
      backdrop-filter: saturate(160%) blur(20px);
      -webkit-backdrop-filter: saturate(160%) blur(20px);
      border-bottom: 1px solid rgba(17,17,17,.08);
      box-shadow: none;
    }
    .luxense-navbar__inner {
      max-width: 1560px;
      margin: 0 auto;
      padding: 0 24px;
      height: 74px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 18px;
    }
    .luxense-navbar__links {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .luxense-navbar__menu {
      display: none;
    }
    .luxense-navbar__menu summary {
      list-style: none;
      width: 42px;
      height: 42px;
      border-radius: 14px;
      border: 1px solid rgba(17,17,17,.1);
      background: rgba(255,255,255,.8);
      display: grid;
      place-items: center;
      cursor: pointer;
      color: var(--fg);
      font-size: 18px;
      font-weight: 700;
    }
    .luxense-navbar__menu summary::-webkit-details-marker { display:none; }
    .luxense-navbar__menu nav {
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: rgba(252,250,247,.98);
      border-bottom: 1px solid var(--border);
      padding: 16px 18px 18px;
      display: grid;
      gap: 10px;
    }
    .luxense-navbar__menu nav a {
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      text-decoration: none;
      font-size: 18px;
      font-weight: 700;
    }
    .luxense-navbar__links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
    }
    .luxense-navbar__brand {
      justify-self: center;
      text-decoration: none;
      color: var(--fg);
    }
    .luxense-navbar__brand span {
      font-family: 'Manrope','Inter',system-ui,sans-serif;
      font-size: 24px;
      line-height: 1;
      letter-spacing: .22em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .luxense-navbar__cart {
      justify-self: end;
      width: 42px;
      height: 42px;
      border-radius: 14px;
      border: 1px solid rgba(17,17,17,.1);
      background: rgba(255,255,255,.8);
      display: grid;
      place-items: center;
      text-decoration: none;
      color: var(--fg);
    }
    @media (max-width: 1040px) {
      .luxense-navbar__links { display: none; }
      .luxense-navbar__menu { display: block; }
      .luxense-navbar__inner { grid-template-columns: auto 1fr auto; height: 68px; }
    }
    @media (max-width: 760px) {
      .luxense-navbar { top: 32px; }
      .luxense-navbar__inner { padding: 0 14px; height: 60px; }
      .luxense-navbar__brand span { font-size: 18px; letter-spacing: .16em; }
      .luxense-navbar__cart { width: 38px; height: 38px; border-radius: 12px; }
      .luxense-navbar__menu summary { width: 38px; height: 38px; border-radius: 12px; }
    }
  </style>
</header>

{% schema %}
{
  "name": "Luxense navbar",
  "tag": "section",
  "class": "luxense-navbar-section",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "LUXENSE" },
    { "type": "url", "id": "cart_link", "label": "Cart link" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Shop" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxense navbar",
      "blocks": [
        { "type": "link", "settings": { "label": "Shop", "link": "#luxense-bundles" } },
        { "type": "link", "settings": { "label": "Spaces", "link": "#luxense-use-cases" } },
        { "type": "link", "settings": { "label": "Reviews", "link": "#luxense-faq" } },
        { "type": "link", "settings": { "label": "Our Story", "link": "#luxense-guarantee" } }
      ]
    }
  ]
}
{% endschema %}
