<section class="luxense-basic" id="luxense-light-tones">
  <div class="luxense-wrap">
    <div class="luxense-head">
      <p class="luxense-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="luxense-grid luxense-tone-grid">
      {% for block in section.blocks %}
        <article class="luxense-card luxense-tone" {{ block.shopify_attributes }}>
          <div class="luxense-tone__swatch" style="background: {{ block.settings.swatch }};"></div>
          <h3>{{ block.settings.title }}</h3>
          <p class="luxense-tone__meta">{{ block.settings.tone }}</p>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
  <style>
    .luxense-tone-grid{grid-template-columns:repeat(3,minmax(0,1fr));margin-top:38px}
    .luxense-tone{padding:24px}
    .luxense-tone__swatch{height:92px;border-radius:20px;border:1px solid rgba(17,17,17,.08)}
    .luxense-tone h3{margin:16px 0 0;font-size:24px;line-height:1.08;font-weight:800}
    .luxense-tone__meta{margin:8px 0 0;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:700}
    .luxense-tone p:last-child{margin:10px 0 0;font-size:15px;line-height:1.7;color:var(--muted)}
    @media (max-width:1040px){.luxense-tone-grid{grid-template-columns:1fr}}
  </style>
</section>
