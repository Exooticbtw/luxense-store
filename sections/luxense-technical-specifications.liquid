<section class="luxense-basic" id="luxense-technical-specifications">
  <div class="luxense-wrap">
    <div class="luxense-head">
      <p class="luxense-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
    </div>
    <div class="luxense-grid luxense-spec-grid">
      {% for block in section.blocks %}
        <div class="luxense-card luxense-spec" {{ block.shopify_attributes }}>
          <small>{{ block.settings.label }}</small>
          <div>{{ block.settings.value }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
  <style>
    .luxense-spec-grid{grid-template-columns:repeat(2,minmax(0,1fr));margin-top:38px}
    .luxense-spec{display:flex;justify-content:space-between;gap:18px;align-items:flex-start;padding:22px;border-radius:24px}
    .luxense-spec small{font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
    .luxense-spec div{font-size:16px;line-height:1.55;text-align:right;max-width:320px;color:var(--muted)}
    @media (max-width:1040px){.luxense-spec-grid{grid-template-columns:1fr}}
    @media (max-width:760px){.luxense-spec{flex-direction:column}.luxense-spec div{text-align:left;max-width:none}}
  </style>
</section>
{% schema %}
{"name":"Luxense technical specifications","tag":"section","class":"luxense-technical-specifications","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Technical specifications"},{"type":"textarea","id":"title","label":"Title","default":"Everything you need, laid out clearly."}],"blocks":[{"type":"spec","name":"Spec","settings":[{"type":"text","id":"label","label":"Label","default":"Product name"},{"type":"text","id":"value","label":"Value","default":"Luxense MotionGlow"}]}],"presets":[{"name":"Luxense technical specifications","blocks":[{"type":"spec","settings":{"label":"Product name","value":"Luxense MotionGlow"}},{"type":"spec","settings":{"label":"Type","value":"Wireless LED motion sensor night light"}},{"type":"spec","settings":{"label":"Motion detection angle","value":"120°"}},{"type":"spec","settings":{"label":"Auto-off","value":"About 15 seconds without motion"}},{"type":"spec","settings":{"label":"Brightness","value":"Adjustable from 10% to 100%"}},{"type":"spec","settings":{"label":"Light tones","value":"Warm Light 3000K / Neutral Light 4000K / White Light 6000K"}},{"type":"spec","settings":{"label":"Colors","value":"White / Black"}},{"type":"spec","settings":{"label":"Sizes","value":"20cm / 30cm / 40cm / 50cm"}}]}]}{% endschema %}
