{% liquid
  assign luxense_product = section.settings.product
  if luxense_product == blank and product
    assign luxense_product = product
  endif
  assign luxense_default_variant_id = section.settings.default_variant_id
  if luxense_default_variant_id == blank and luxense_product != blank
    assign luxense_default_variant_id = luxense_product.selected_or_first_available_variant.id
  endif
  assign luxense_announcement_messages = section.settings.announcement_messages | split: "|"
%}

<script>
  window.__LUXENSE_SHOPIFY_DATA__ = {
    shopName: {{ shop.name | json }},
    shopDomain: {{ shop.permanent_domain | json }},
    currency: {{ cart.currency.iso_code | default: shop.currency | json }},
    targetProductId: {{ section.settings.target_product_id | json }},
    defaultVariantId: {{ luxense_default_variant_id | default: blank | json }},
    productHandle: {{ section.settings.product_handle | json }},
    productUrl: {% if luxense_product != blank %}{{ "/products/" | append: luxense_product.handle | json }}{% else %}{{ section.settings.product_url | json }}{% endif %},
    theme: {
      pageBackground: {{ section.settings.page_background | json }},
      creamText: {{ section.settings.cream_text | json }},
      warmWhite: {{ section.settings.warm_white | json }},
      mainText: {{ section.settings.main_text | json }},
      mutedText: {{ section.settings.muted_text | json }},
      accent: {{ section.settings.accent | json }},
      borders: {{ section.settings.borders | json }},
      darkBackground: {{ section.settings.dark_background | json }}
    },
    announcement: {
      messages: {% if section.settings.announcement_messages != blank %}{{ luxense_announcement_messages | json }}{% else %}[]{% endif %}
    },
    product: {% if luxense_product != blank %}
      {
        id: {{ luxense_product.id | json }},
        handle: {{ luxense_product.handle | json }},
        title: {{ luxense_product.title | json }},
        description: {{ luxense_product.description | strip_html | json }},
        featuredImage: {% if luxense_product.featured_image %}{{ luxense_product.featured_image | image_url: width: 1600 | json }}{% else %}null{% endif %},
        images: [
          {% for image in luxense_product.images %}
            {{ image | image_url: width: 1600 | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],
        variants: [
          {% for variant in luxense_product.variants %}
            {
              id: {{ variant.id | json }},
              title: {{ variant.title | json }},
              price: {{ variant.price | divided_by: 100.0 | json }},
              available: {{ variant.available | json }},
              image: {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1600 | json }}{% else %}null{% endif %},
              options: {{ variant.options | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }
    {% else %}
      null
    {% endif %},
    hero: {
      heroEyebrow: {{ section.settings.hero_eyebrow | json }},
