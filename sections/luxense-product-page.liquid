{% liquid
  assign luxense_product = section.settings.product
  if luxense_product == blank and product
    assign luxense_product = product
  endif
  assign luxense_default_variant_id = section.settings.default_variant_id
  if luxense_default_variant_id == blank and luxense_product != blank
    assign luxense_default_variant_id = luxense_product.selected_or_first_available_variant.id
  endif
%}

<script>
  window.__LUXENSE_SHOPIFY_DATA__ = {
    shopName: {{ shop.name | json }},
    shopDomain: {{ shop.permanent_domain | json }},
    currency: {{ cart.currency.iso_code | default: shop.currency | json }},
    media: {
      heroImage: {% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 2400 | json }}{% else %}null{% endif %},
      productImage: {% if section.settings.product_image != blank %}{{ section.settings.product_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      bedroomImage: {% if section.settings.bedroom_image != blank %}{{ section.settings.bedroom_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      closetImage: {% if section.settings.closet_image != blank %}{{ section.settings.closet_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      kitchenImage: {% if section.settings.kitchen_image != blank %}{{ section.settings.kitchen_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      hallwayImage: {% if section.settings.hallway_image != blank %}{{ section.settings.hallway_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      staircaseImage: {% if section.settings.staircase_image != blank %}{{ section.settings.staircase_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      wardrobeImage: {% if section.settings.wardrobe_image != blank %}{{ section.settings.wardrobe_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
      finalCtaImage: {% if section.settings.final_cta_image != blank %}{{ section.settings.final_cta_image | image_url: width: 2400 | json }}{% else %}null{% endif %},
      reviewImage1: {% if section.settings.review_image_1 != blank %}{{ section.settings.review_image_1 | image_url: width: 900 | json }}{% else %}null{% endif %},
      reviewImage2: {% if section.settings.review_image_2 != blank %}{{ section.settings.review_image_2 | image_url: width: 900 | json }}{% else %}null{% endif %},
      reviewImage3: {% if section.settings.review_image_3 != blank %}{{ section.settings.review_image_3 | image_url: width: 900 | json }}{% else %}null{% endif %},
      reviewImage4: {% if section.settings.review_image_4 != blank %}{{ section.settings.review_image_4 | image_url: width: 900 | json }}{% else %}null{% endif %},
      galleryImages: [
        {% if section.settings.gallery_image_1 != blank %}{{ section.settings.gallery_image_1 | image_url: width: 1600 | json }}{% else %}null{% endif %},
        {% if section.settings.gallery_image_2 != blank %}{{ section.settings.gallery_image_2 | image_url: width: 1600 | json }}{% else %}null{% endif %},
        {% if section.settings.gallery_image_3 != blank %}{{ section.settings.gallery_image_3 | image_url: width: 1600 | json }}{% else %}null{% endif %},
        {% if section.settings.gallery_image_4 != blank %}{{ section.settings.gallery_image_4 | image_url: width: 1600 | json }}{% else %}null{% endif %},
        {% if section.settings.gallery_image_5 != blank %}{{ section.settings.gallery_image_5 | image_url: width: 1600 | json }}{% else %}null{% endif %},
        {% if section.settings.gallery_image_6 != blank %}{{ section.settings.gallery_image_6 | image_url: width: 1600 | json }}{% else %}null{% endif %}
      ]
    },
    theme: {
      bgColor: {{ section.settings.bg_color | json }},
      creamColor: {{ section.settings.cream_color | json }},
      warmWhiteColor: {{ section.settings.warm_white_color | json }},
      textColor: {{ section.settings.text_color | json }},
      mutedColor: {{ section.settings.muted_color | json }},
      accentColor: {{ section.settings.accent_color | json }},
      borderColor: {{ section.settings.border_color | json }},
      announcementText: {{ section.settings.announcement_text | json }},
      heroEyebrow: {{ section.settings.hero_eyebrow | json }},
      heroTitle: {{ section.settings.hero_title | json }},
      heroText: {{ section.settings.hero_text | json }},
      heroPrimaryButton: {{ section.settings.hero_primary_button | json }},
      heroSecondaryButton: {{ section.settings.hero_secondary_button | json }},
      featuresEyebrow: {{ section.settings.features_eyebrow | json }},
      featuresTitle: {{ section.settings.features_title | json }},
      featuresText: {{ section.settings.features_text | json }},
      productEyebrow: {{ section.settings.product_eyebrow | json }},
      productTitle: {{ section.settings.product_title | json }},
      productDescription: {{ section.settings.product_description | json }},
      productPrice: {{ section.settings.product_price | json }},
      productCompareAt: {{ section.settings.product_compare_at | json }},
      productBadge: {{ section.settings.product_badge | json }},
      productButton: {{ section.settings.product_button | json }},
      detailPrice: {{ section.settings.detail_price | json }},
      detailCompareAt: {{ section.settings.detail_compare_at | json }},
      detailBadge: {{ section.settings.detail_badge | json }},
      singlePrice: {{ section.settings.single_price | json }},
      singleCompareAt: {{ section.settings.single_compare_at | json }},
      duoPrice: {{ section.settings.duo_price | json }},
      duoCompareAt: {{ section.settings.duo_compare_at | json }},
      trioPrice: {{ section.settings.trio_price | json }},
      trioCompareAt: {{ section.settings.trio_compare_at | json }},
      addToCartButton: {{ section.settings.add_to_cart_button | json }},
      buyNowButton: {{ section.settings.buy_now_button | json }},
      roomsTitle: {{ section.settings.rooms_title | json }},
      plannerTitle: {{ section.settings.planner_title | json }},
      plannerText: {{ section.settings.planner_text | json }},
      faqEyebrow: {{ section.settings.faq_eyebrow | json }},
      faqTitle: {{ section.settings.faq_title | json }},
      faqQuestion1: {{ section.settings.faq_question_1 | json }},
      faqAnswer1: {{ section.settings.faq_answer_1 | json }},
      faqQuestion2: {{ section.settings.faq_question_2 | json }},
      faqAnswer2: {{ section.settings.faq_answer_2 | json }},
      faqQuestion3: {{ section.settings.faq_question_3 | json }},
      faqAnswer3: {{ section.settings.faq_answer_3 | json }},
      faqQuestion4: {{ section.settings.faq_question_4 | json }},
      faqAnswer4: {{ section.settings.faq_answer_4 | json }},
      faqQuestion5: {{ section.settings.faq_question_5 | json }},
      faqAnswer5: {{ section.settings.faq_answer_5 | json }},
      finalCtaTitle: {{ section.settings.final_cta_title | json }},
      finalCtaText: {{ section.settings.final_cta_text | json }},
      finalCtaButton: {{ section.settings.final_cta_button | json }},
      footerText: {{ section.settings.footer_text | json }},
      footerEmailPlaceholder: {{ section.settings.footer_email_placeholder | json }},
      footerButton: {{ section.settings.footer_button | json }}
    },
    targetProductId: {{ section.settings.target_product_id | default: blank | json }},
    preferredVariantId: {{ luxense_default_variant_id | default: blank | json }},
    productUrl: {% if luxense_product != blank %}{{ "/products/" | append: luxense_product.handle | json }}{% else %}null{% endif %},
    product: {% if luxense_product != blank %}
      {
        id: {{ luxense_product.id | json }},
        handle: {{ luxense_product.handle | json }},
        title: {{ luxense_product.title | json }},
        description: {{ luxense_product.description | strip_html | json }},
        featuredImage: {% if luxense_product.featured_image %}
          {{ luxense_product.featured_image | image_url: width: 1600 | json }}
        {% else %}
          null
        {% endif %},
        images: [
          {% for image in luxense_product.images %}
            {{ image | image_url: width: 1600 | json }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],
        variants: [
          {% for variant in luxense_product.variants %}
            {
              id: {{ variant.id | json }},
              title: {{ variant.title | json }},
              price: {{ variant.price | divided_by: 100.0 | json }},
              available: {{ variant.available | json }},
              image: {% if variant.featured_image %}
                {{ variant.featured_image | image_url: width: 1600 | json }}
              {% else %}
                null
              {% endif %},
              options: {{ variant.options | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }
    {% else %}
      null
    {% endif %}
  };
</script>

<div id="luxense-product-page-root"></div>

