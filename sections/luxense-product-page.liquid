<div id="luxense-product-page-root"></div>

{% schema %}
{
  "name": "Luxense product page",
  "tag": "section",
  "class": "luxense-product-page-section",
  "settings": [
    { "type": "paragraph", "content": "React-powered Luxense MotionGlow product landing page." },
    { "type": "product", "id": "product", "label": "Product", "info": "Select the Shopify product to show." },
    { "type": "text", "id": "target_product_id", "label": "Target product ID", "default": "8290980200492" },
    { "type": "text", "id": "default_variant_id", "label": "Default variant ID", "info": "Optional. Leave blank to use the product's first available variant." },
    { "type": "text", "id": "product_handle", "label": "Product handle", "default": "motion-sensor-light-led-sensor-lamp-wireless-ultra-thin-usb-led-for-kitchen-cabinet-bedroom-wardrobe-indoor-lighting-night-light" },
    { "type": "text", "id": "product_url", "label": "Product URL", "default": "/products/motion-sensor-light-led-sensor-lamp-wireless-ultra-thin-usb-led-for-kitchen-cabinet-bedroom-wardrobe-indoor-lighting-night-light" },
    { "type": "header", "content": "Theme colors" },
    { "type": "color", "id": "page_background", "label": "Page background", "default": "#F6F4EF" },
    { "type": "color", "id": "cream_text", "label": "Cream text", "default": "#FBFAF6" },
    { "type": "color", "id": "warm_white", "label": "Warm white", "default": "#FFFDF8" },
    { "type": "color", "id": "main_text", "label": "Main text", "default": "#231913" },
    { "type": "color", "id": "muted_text", "label": "Muted text", "default": "#74685D" },
    { "type": "color", "id": "accent", "label": "Accent", "default": "#C89A59" },
    { "type": "color", "id": "borders", "label": "Borders", "default": "#DED8CF" },
    { "type": "color", "id": "dark_background", "label": "Dark background", "default": "#111111" },
    { "type": "header", "content": "Announcement bar" },
    { "type": "textarea", "id": "announcement_messages", "label": "Announcement messages", "default": "Free shipping over $35 | Secure checkout | 30-day money-back guarantee | Fast human support" },
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "Premium Motion Lighting For Modern Homes" },
    { "type": "textarea", "id": "hero_title", "label": "Hero title", "default": "Luxense MotionGlow™" },
    { "type": "textarea", "id": "hero_description", "label": "Hero description", "default": "Premium motion lighting for a calmer, safer home. Luxense MotionGlow turns on automatically when you move, adding soft ambient light exactly where you need it." },
    { "type": "text", "id": "hero_primary_button", "label": "Hero primary button", "default": "Get Yours Today" },
    { "type": "text", "id": "hero_secondary_button", "label": "Hero secondary button", "default": "See It In Action" },
    { "type": "text", "id": "hero_rating_text", "label": "Hero rating text", "default": "4.9/5 Rating" },
    { "type": "text", "id": "hero_customer_text", "label": "Hero customer text", "default": "3,000+ Happy Customers" },
    { "type": "header", "content": "Purchase" },
