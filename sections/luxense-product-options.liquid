<section class="luxense-options" id="luxense-options">
  <div class="luxense-wrap">
    <div class="luxense-head">
      <p class="luxense-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="luxense-options__grid">
      <article class="luxense-card luxense-options__panel luxense-options__panel--light">
        <div class="luxense-options__panel-head">
          <h3>{{ section.settings.color_title }}</h3>
          <span>Selected: {{ section.settings.selected_color_label }} - {{ section.settings.selected_size_label }}</span>
        </div>
        <div class="luxense-options__choices luxense-options__choices--colors">
          {% for block in section.blocks %}
            {% if block.type == 'color' %}
              <button class="luxense-option {% if block.settings.selected %}is-selected{% endif %}" type="button" {{ block.shopify_attributes }}>
                <span class="luxense-swatch" style="background: {{ block.settings.swatch }};"></span>
                <span>
                  <strong>{{ block.settings.label }}</strong>
                  <small>{{ block.settings.caption }}</small>
                </span>
              </button>
            {% endif %}
          {% endfor %}
        </div>
      </article>

      <article class="luxense-card luxense-options__panel luxense-options__panel--dark">
        <div class="luxense-options__panel-head">
          <h3>{{ section.settings.size_title }}</h3>
          <span>{{ section.settings.selected_size_label }}</span>
        </div>
        <div class="luxense-options__choices luxense-options__choices--sizes">
          {% for block in section.blocks %}
            {% if block.type == 'size' %}
              <button class="luxense-option {% if block.settings.selected %}is-selected{% endif %}" type="button" {{ block.shopify_attributes }}>
                <span>
                  <strong>{{ block.settings.label }}</strong>
                  <small>{{ block.settings.caption }}</small>
                </span>
              </button>
            {% endif %}
          {% endfor %}
        </div>
      </article>
    </div>
  </div>

  <style>
    .luxense-options { padding:86px 24px; background:var(--bg); }
    .luxense-wrap { max-width:1560px; margin:0 auto; }
    .luxense-head { max-width:700px; }
    .luxense-eyebrow { font-size:12px; text-transform:uppercase; letter-spacing:.24em; color:var(--accent); margin:0 0 10px; }
    .luxense-head h2 { font-family:'Manrope','Inter',system-ui,sans-serif; font-size:64px; line-height:1.02; letter-spacing:-.04em; margin:0; }
    .luxense-head p { margin:18px 0 0; font-size:18px; line-height:1.7; color:var(--muted); }
    .luxense-options__grid { display:grid; grid-template-columns:1.1fr .9fr; gap:18px; margin-top:38px; align-items:start; }
    .luxense-options__panel { padding:24px; border-radius:28px; }
    .luxense-options__panel--dark { background:#111111; color:#ffffff; }
    .luxense-options__panel--light { background:rgba(255,255,255,.86); }
    .luxense-options__panel-head { display:flex; align-items:center; justify-content:space-between; gap:16px; }
    .luxense-options__panel-head h3 { margin:0; font-size:18px; font-weight:800; }
    .luxense-options__panel-head span { font-size:12px; font-weight:700; color:var(--muted); background:rgba(17,17,17,.03); border:1px solid rgba(17,17,17,.08); padding:8px 12px; border-radius:999px; }
    .luxense-options__panel--dark .luxense-options__panel-head span { color:rgba(255,255,255,.76); background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.12); }
    .luxense-options__choices { display:grid; gap:12px; margin-top:18px; }
    .luxense-options__choices--colors { grid-template-columns: repeat(2, minmax(0,1fr)); }
    .luxense-options__choices--sizes { grid-template-columns: repeat(2, minmax(0,1fr)); }
    .luxense-option {
      min-height: 92px; border-radius:22px; border:1px solid rgba(17,17,17,.08); background:rgba(255,255,255,.8);
      display:flex; align-items:center; gap:14px; padding:16px; text-align:left; cursor:default;
      box-shadow: 0 8px 22px rgba(17,17,17,.05);
    }
    .luxense-options__panel--dark .luxense-option {
      background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.12); color:#ffffff; box-shadow:none;
    }
    .luxense-option.is-selected { border-color: var(--accent); background: rgba(200,169,106,.08); }
    .luxense-swatch { width:34px; height:34px; border-radius:50%; flex-shrink:0; border:1px solid rgba(17,17,17,.08); box-shadow: inset 0 0 0 1px rgba(255,255,255,.18); }
    .luxense-option strong { display:block; font-size:15px; font-weight:800; }
    .luxense-option small { display:block; margin-top:3px; font-size:13px; color:var(--muted); }
    .luxense-options__panel--dark .luxense-option small { color: rgba(255,255,255,.72); }
    @media (max-width: 1040px) { .luxense-options__grid { grid-template-columns:1fr; } }
    @media (max-width: 760px) {
      .luxense-options { padding:64px 16px; }
      .luxense-head h2 { font-size:40px; }
      .luxense-options__panel { padding:20px; border-radius:24px; }
      .luxense-options__panel-head { flex-direction:column; align-items:flex-start; }
      .luxense-options__panel-head span { width:100%; }
      .luxense-options__choices--colors, .luxense-options__choices--sizes { grid-template-columns: 1fr; }
      .luxense-option { min-height: 84px; border-radius:18px; }
    }
  </style>
</section>

{% schema %}
{
  "name": "Luxense product options",
  "tag": "section",
  "class": "luxense-product-options",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Color and size options" },
    { "type": "textarea", "id": "title", "label": "Title", "default": "Make it match your space." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Choose a finish and length that blend naturally into the room, with clear selection feedback as you shop." },
    { "type": "text", "id": "color_title", "label": "Color title", "default": "Finish" },
    { "type": "text", "id": "size_title", "label": "Size title", "default": "Length" },
    { "type": "text", "id": "selected_color_label", "label": "Selected color label", "default": "White" },
    { "type": "text", "id": "selected_size_label", "label": "Selected size label", "default": "30cm" }
  ],
  "blocks": [
    {
      "type": "color",
      "name": "Color option",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "White" },
        { "type": "text", "id": "caption", "label": "Caption", "default": "Premium matte finish" },
        { "type": "text", "id": "swatch", "label": "Swatch color", "default": "#F6F6F4" },
        { "type": "checkbox", "id": "selected", "label": "Selected", "default": false }
      ]
    },
    {
      "type": "size",
      "name": "Size option",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "30cm" },
        { "type": "textarea", "id": "caption", "label": "Caption", "default": "Great for closets, shelves, and wardrobes." },
        { "type": "checkbox", "id": "selected", "label": "Selected", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxense product options",
      "blocks": [
        { "type": "color", "settings": { "label": "White", "caption": "Premium matte finish", "swatch": "#F6F6F4", "selected": true } },
        { "type": "color", "settings": { "label": "Black", "caption": "Premium matte finish", "swatch": "#171717", "selected": false } },
        { "type": "size", "settings": { "label": "20cm", "caption": "Best for drawers, small cabinets, compact spaces.", "selected": false } },
        { "type": "size", "settings": { "label": "30cm", "caption": "Great for closets, shelves, and wardrobes.", "selected": true } },
        { "type": "size", "settings": { "label": "40cm", "caption": "Ideal for kitchen cabinets, counters, and medium areas.", "selected": false } },
        { "type": "size", "settings": { "label": "50cm", "caption": "Best for wider closets, larger cabinets, and larger spaces.", "selected": false } }
      ]
    }
  ]
}
{% endschema %}
