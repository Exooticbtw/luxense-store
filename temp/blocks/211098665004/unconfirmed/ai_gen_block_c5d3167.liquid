{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-featured-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-featured-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: #ffffff;
  }

  .ai-magazine-category-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    border-radius: 2px;
  }

  .ai-magazine-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px;
    color: #ffffff;
  }

  .ai-magazine-featured-excerpt-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.5;
    margin: 0 0 16px;
    color: rgba(255, 255, 255, 0.9);
  }

  .ai-magazine-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-sidebar-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    padding: 16px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-magazine-sidebar-item-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-magazine-sidebar-image-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: {{ block.settings.border_radius }}px;
    flex-shrink: 0;
  }

  .ai-magazine-sidebar-placeholder-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.border_radius }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-sidebar-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-sidebar-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-magazine-sidebar-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-sidebar-meta-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-bottom-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-magazine-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-magazine-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-card-content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-magazine-card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-card-excerpt-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 12px;
    color: {{ block.settings.meta_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-featured-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-magazine-bottom-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-magazine-featured-image-{{ ai_gen_id }},
    .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
      height: 300px;
    }

    .ai-magazine-featured-content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-magazine-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.6 }}px;
    }

    .ai-magazine-bottom-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-sidebar-item-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-magazine-sidebar-image-{{ ai_gen_id }},
    .ai-magazine-sidebar-placeholder-{{ ai_gen_id }} {
      width: 100%;
      height: 150px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }} class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-grid-{{ ai_gen_id }}">
    <article class="ai-magazine-featured-{{ ai_gen_id }}">
      {% if block.settings.featured_image %}
        <img
          src="{{ block.settings.featured_image | image_url: width: 1200 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          class="ai-magazine-featured-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
        >
      {% else %}
        <div class="ai-magazine-featured-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      <div class="ai-magazine-featured-content-{{ ai_gen_id }}">
        {% if block.settings.featured_category != blank %}
          <span class="ai-magazine-category-{{ ai_gen_id }}">{{ block.settings.featured_category }}</span>
        {% endif %}
        {% if block.settings.featured_title != blank %}
          <h2 class="ai-magazine-featured-title-{{ ai_gen_id }}">{{ block.settings.featured_title }}</h2>
        {% endif %}
        {% if block.settings.featured_excerpt != blank %}
          <p class="ai-magazine-featured-excerpt-{{ ai_gen_id }}">{{ block.settings.featured_excerpt }}</p>
        {% endif %}
        <div class="ai-magazine-meta-{{ ai_gen_id }}">
          {% if block.settings.featured_author != blank %}
            <span>{{ block.settings.featured_author }}</span>
          {% endif %}
          {% if block.settings.featured_date != blank %}
            <span>{{ block.settings.featured_date }}</span>
          {% endif %}
        </div>
      </div>
    </article>

    <aside class="ai-magazine-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'sidebar_image_' | append: i
          assign title_key = 'sidebar_title_' | append: i
          assign date_key = 'sidebar_date_' | append: i

          assign sidebar_image = block.settings[image_key]
          assign sidebar_title = block.settings[title_key]
          assign sidebar_date = block.settings[date_key]
        %}
        <article class="ai-magazine-sidebar-item-{{ ai_gen_id }}">
          {% if sidebar_image %}
            <img
              src="{{ sidebar_image | image_url: width: 200 }}"
              alt="{{ sidebar_image.alt | escape }}"
              class="ai-magazine-sidebar-image-{{ ai_gen_id }}"
              loading="lazy"
              width="100"
              height="100"
            >
          {% else %}
            <div class="ai-magazine-sidebar-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-magazine-sidebar-content-{{ ai_gen_id }}">
            {% if sidebar_title != blank %}
              <h3 class="ai-magazine-sidebar-title-{{ ai_gen_id }}">{{ sidebar_title }}</h3>
            {% endif %}
            {% if sidebar_date != blank %}
              <div class="ai-magazine-sidebar-meta-{{ ai_gen_id }}">{{ sidebar_date }}</div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </aside>
  </div>

  <div class="ai-magazine-bottom-grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign card_image_key = 'card_image_' | append: i
        assign card_title_key = 'card_title_' | append: i
        assign card_excerpt_key = 'card_excerpt_' | append: i
        assign card_date_key = 'card_date_' | append: i

        assign card_image = block.settings[card_image_key]
        assign card_title = block.settings[card_title_key]
        assign card_excerpt = block.settings[card_excerpt_key]
        assign card_date = block.settings[card_date_key]
      %}
      <article class="ai-magazine-card-{{ ai_gen_id }}">
        {% if card_image %}
          <img
            src="{{ card_image | image_url: width: 600 }}"
            alt="{{ card_image.alt | escape }}"
            class="ai-magazine-card-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ card_image.width }}"
            height="{{ card_image.height }}"
          >
        {% else %}
          <div class="ai-magazine-card-placeholder-{{ ai_gen_id }}">
            {{ 'collection-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-magazine-card-content-{{ ai_gen_id }}">
          {% if card_title != blank %}
            <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}
          {% if card_excerpt != blank %}
            <p class="ai-magazine-card-excerpt-{{ ai_gen_id }}">{{ card_excerpt }}</p>
          {% endif %}
          {% if card_date != blank %}
            <div class="ai-magazine-sidebar-meta-{{ ai_gen_id }}">{{ card_date }}</div>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const articles = this.querySelectorAll('article');
        articles.forEach((article) => {
          article.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ ai_gen_id }});
  })();
</script>

