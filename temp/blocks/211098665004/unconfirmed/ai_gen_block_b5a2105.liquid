{% doc %}
  @prompt
    Actúa como un desarrollador senior especializado en Shopify, UX/UI, conversión y diseño mobile-first.
    
    Analiza el proyecto completo y crea una NUEVA SECCIÓN PERSONALIZADA DE SHOPIFY optimizada para dispositivos móviles.
    
    OBJETIVO:
    Diseñar una sección premium que aumente la confianza, el tiempo de permanencia y la conversión del usuario.
    
    REQUISITOS GENERALES:
    
    - Crear una sección independiente dentro de Shopify.
    - Compatible con Shopify Online Store 2.0.
    - Código limpio y modular.
    - Utilizar Liquid, HTML, CSS y JavaScript nativo.
    - Mantener compatibilidad con todos los temas modernos de Shopify.
    - No afectar otras secciones existentes.
    - Rendimiento optimizado.
    - Accesibilidad y SEO optimizados.
    
    DISEÑO MOBILE-FIRST:
    
    - Priorizar experiencia móvil antes que escritorio.
    - Diseño visual premium tipo marcas de lujo y ecommerce de alto nivel.
    - Espaciado profesional.
    - Tipografía moderna.
    - Animaciones suaves.
    - Transiciones fluidas.
    - Carga rápida.
    - Adaptación perfecta para:
      - iPhone
      - Android
      - Tablets
    
    COMPONENTES DE LA SECCIÓN:
    
    1. Encabezado atractivo.
    2. Imagen o video principal optimizado.
    3. Beneficios destacados con iconos.
    4. Elementos de confianza.
    5. Testimonios dinámicos.
    6. Indicadores visuales de calidad.
    7. Llamado a la acción potente.
    8. Botón de compra destacado.
    9. Efectos visuales modernos.
    10. Microanimaciones premium.
    
    BOTONES:
    
    - Todos los botones deben funcionar correctamente.
    - Estados hover, active y disabled.
    - Animaciones suaves al hacer clic.
    - Feedback visual inmediato.
    - Compatibilidad táctil para móviles.
    - Áreas táctiles grandes para facilitar la interacción.
    
    EXPERIENCIA DE USUARIO:
    
    - Sensación de aplicación premium.
    - Navegación intuitiva.
    - Jerarquía visual clara.
    - Diseño enfocado en conversión.
    - Evitar elementos genéricos.
    - Aspecto profesional y moderno.
    
    PERSONALIZACIÓN SHOPIFY:
    
    Crear configuraciones completas en schema para que el comerciante pueda modificar:
    
    - Títulos.
    - Subtítulos.
    - Imágenes.
    - Videos.
    - Colores.
    - Textos.
    - Botones.
    - Iconos.
    - Espaciados.
    - Fondos.
    
    ENTREGABLE:
    
    Genera el archivo completo de sección Shopify listo para copiar y pegar dentro de /sections.
    
    Incluye:
    - Liquid completo.
    - CSS integrado.
    - JavaScript integrado.
    - Schema completo.
    - Comentarios explicativos.
    - Código listo para producción.
    
    El resultado debe verse como una sección premium de una marca que factura millones de dólares al año y debe superar visualmente las secciones estándar de Shopify.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-premium-conversion-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ block.settings.section_background }};
    position: relative;
    overflow: hidden;
  }

  .ai-premium-conversion__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.mobile_padding }}px 20px;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__container-{{ ai_gen_id }} {
      padding: {{ block.settings.desktop_padding }}px 40px;
    }
  }

  .ai-premium-conversion__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
    animation: ai-fade-in-up-{{ ai_gen_id }} 0.8s ease-out;
  }

  .ai-premium-conversion__eyebrow-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: 12px;
    display: block;
  }

  .ai-premium-conversion__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.mobile_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_title_size }}px;
    }
  }

  .ai-premium-conversion__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.mobile_subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_subtitle_size }}px;
    }
  }

  .ai-premium-conversion__media-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 40px;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    animation: ai-fade-in-{{ ai_gen_id }} 1s ease-out 0.2s both;
  }

  .ai-premium-conversion__media-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background: #f5f5f5;
  }

  .ai-premium-conversion__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-premium-conversion__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-premium-conversion__media-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .ai-premium-conversion__media-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-premium-conversion__benefits-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 48px;
    animation: ai-fade-in-{{ ai_gen_id }} 1s ease-out 0.4s both;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__benefits-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.benefits_columns }}, 1fr);
      gap: 32px;
    }
  }

  .ai-premium-conversion__benefit-{{ ai_gen_id }} {
    background: {{ block.settings.benefit_background }};
    padding: 28px 24px;
    border-radius: {{ block.settings.benefit_border_radius }}px;
    text-align: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid {{ block.settings.benefit_border_color }};
  }

  .ai-premium-conversion__benefit-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
  }

  .ai-premium-conversion__benefit-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.icon_background }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .ai-premium-conversion__benefit-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-premium-conversion__benefit-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.benefit_title_color }};
    margin: 0 0 8px;
  }

  .ai-premium-conversion__benefit-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.benefit_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-premium-conversion__trust-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px;
    margin-bottom: 48px;
    padding: 32px 20px;
    background: {{ block.settings.trust_background }};
    border-radius: {{ block.settings.trust_border_radius }}px;
    animation: ai-fade-in-{{ ai_gen_id }} 1s ease-out 0.6s both;
  }

  .ai-premium-conversion__trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.trust_text_color }};
  }

  .ai-premium-conversion__trust-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.trust_icon_color }};
    flex-shrink: 0;
  }

  .ai-premium-conversion__testimonials-{{ ai_gen_id }} {
    margin-bottom: 48px;
    animation: ai-fade-in-{{ ai_gen_id }} 1s ease-out 0.8s both;
  }

  .ai-premium-conversion__testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.testimonials_columns }}, 1fr);
    }
  }

  .ai-premium-conversion__testimonial-{{ ai_gen_id }} {
    background: {{ block.settings.testimonial_background }};
    padding: 28px;
    border-radius: {{ block.settings.testimonial_border_radius }}px;
    border: 1px solid {{ block.settings.testimonial_border_color }};
    transition: all 0.3s ease;
  }

  .ai-premium-conversion__testimonial-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .ai-premium-conversion__testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-premium-conversion__testimonial-text-{{ ai_gen_id }} {
    font-size: 15px;
    line-height: 1.6;
    color: {{ block.settings.testimonial_text_color }};
    margin: 0 0 20px;
    font-style: italic;
  }

  .ai-premium-conversion__testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-premium-conversion__testimonial-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: {{ block.settings.avatar_text_color }};
    font-size: 18px;
  }

  .ai-premium-conversion__testimonial-info-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-premium-conversion__testimonial-name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.author_name_color }};
    margin: 0 0 4px;
  }

  .ai-premium-conversion__testimonial-role-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.author_role_color }};
    margin: 0;
  }

  .ai-premium-conversion__cta-{{ ai_gen_id }} {
    text-align: center;
    animation: ai-fade-in-up-{{ ai_gen_id }} 1s ease-out 1s both;
  }

  .ai-premium-conversion__cta-text-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.cta_text_color }};
    margin: 0 0 24px;
  }

  .ai-premium-conversion__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 400px;
    margin: 0 auto;
  }

  @media (min-width: 750px) {
    .ai-premium-conversion__buttons-{{ ai_gen_id }} {
      flex-direction: row;
      justify-content: center;
      max-width: none;
    }
  }

  .ai-premium-conversion__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 18px 40px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
    min-height: 56px;
    position: relative;
    overflow: hidden;
  }

  .ai-premium-conversion__button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .ai-premium-conversion__button-{{ ai_gen_id }}:active::before {
    width: 300px;
    height: 300px;
  }

  .ai-premium-conversion__button--primary-{{ ai_gen_id }} {
    background: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    box-shadow: 0 4px 20px {{ block.settings.primary_button_bg }}40;
  }

  .ai-premium-conversion__button--primary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.primary_button_hover }};
    transform: translateY(-2px);
    box-shadow: 0 8px 30px {{ block.settings.primary_button_bg }}60;
  }

  .ai-premium-conversion__button--secondary-{{ ai_gen_id }} {
    background: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_color }};
    border: 2px solid {{ block.settings.secondary_button_border }};
  }

  .ai-premium-conversion__button--secondary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.secondary_button_hover }};
    transform: translateY(-2px);
  }

  .ai-premium-conversion__button-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-premium-conversion__button-{{ ai_gen_id }}:hover .ai-premium-conversion__button-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-premium-conversion__guarantee-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 14px;
    color: {{ block.settings.guarantee_text_color }};
  }

  .ai-premium-conversion__guarantee-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.guarantee_icon_color }};
  }

  @keyframes ai-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes ai-fade-in-up-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-premium-conversion-{{ ai_gen_id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstyle %}

<premium-conversion-{{ ai_gen_id }} class="ai-premium-conversion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-premium-conversion__container-{{ ai_gen_id }}">
    
    <div class="ai-premium-conversion__header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <span class="ai-premium-conversion__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</span>
      {% endif %}
      
      {% if block.settings.title != blank %}
        <h2 class="ai-premium-conversion__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      
      {% if block.settings.subtitle != blank %}
        <p class="ai-premium-conversion__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if block.settings.show_media %}
      <div class="ai-premium-conversion__media-{{ ai_gen_id }}">
        <div class="ai-premium-conversion__media-wrapper-{{ ai_gen_id }}">
          {% if block.settings.media_type == 'image' and block.settings.media_image %}
            <img
              src="{{ block.settings.media_image | image_url: width: 1600 }}"
              alt="{{ block.settings.media_image.alt | escape }}"
              class="ai-premium-conversion__image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.media_image.width }}"
              height="{{ block.settings.media_image.height }}"
            >
          {% elsif block.settings.media_type == 'video' and block.settings.video_url != blank %}
            <video
              class="ai-premium-conversion__video-{{ ai_gen_id }}"
              autoplay
              muted
              loop
              playsinline
            >
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {% else %}
            <div class="ai-premium-conversion__media-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_benefits %}
      <div class="ai-premium-conversion__benefits-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% assign benefit_title_key = 'benefit_' | append: i | append: '_title' %}
          {% assign benefit_text_key = 'benefit_' | append: i | append: '_text' %}
          {% assign benefit_icon_key = 'benefit_' | append: i | append: '_icon' %}
          
          {% assign benefit_title = block.settings[benefit_title_key] %}
          {% assign benefit_text = block.settings[benefit_text_key] %}
          {% assign benefit_icon = block.settings[benefit_icon_key] %}
          
          {% if benefit_title != blank %}
            <div class="ai-premium-conversion__benefit-{{ ai_gen_id }}">
              <div class="ai-premium-conversion__benefit-icon-{{ ai_gen_id }}">
                {% if benefit_icon == 'check' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {% elsif benefit_icon == 'star' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% elsif benefit_icon == 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                {% elsif benefit_icon == 'truck' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
                {% elsif benefit_icon == 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                {% elsif benefit_icon == 'lightning' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/></svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {% endif %}
              </div>
              <h3 class="ai-premium-conversion__benefit-title-{{ ai_gen_id }}">{{ benefit_title }}</h3>
              {% if benefit_text != blank %}
                <p class="ai-premium-conversion__benefit-text-{{ ai_gen_id }}">{{ benefit_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if block.settings.show_trust %}
      <div class="ai-premium-conversion__trust-{{ ai_gen_id }}">
        {% if block.settings.trust_1_text != blank %}
          <div class="ai-premium-conversion__trust-item-{{ ai_gen_id }}">
            <svg class="ai-premium-conversion__trust-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>{{ block.settings.trust_1_text }}</span>
          </div>
        {% endif %}
        
        {% if block.settings.trust_2_text != blank %}
          <div class="ai-premium-conversion__trust-item-{{ ai_gen_id }}">
            <svg class="ai-premium-conversion__trust-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>{{ block.settings.trust_2_text }}</span>
          </div>
        {% endif %}
        
        {% if block.settings.trust_3_text != blank %}
          <div class="ai-premium-conversion__trust-item-{{ ai_gen_id }}">
            <svg class="ai-premium-conversion__trust-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>{{ block.settings.trust_3_text }}</span>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_testimonials %}
      <div class="ai-premium-conversion__testimonials-{{ ai_gen_id }}">
        <div class="ai-premium-conversion__testimonials-grid-{{ ai_gen_id }}">
          {% for i in (1..3) %}
            {% assign testimonial_text_key = 'testimonial_' | append: i | append: '_text' %}
            {% assign testimonial_name_key = 'testimonial_' | append: i | append: '_name' %}
            {% assign testimonial_role_key = 'testimonial_' | append: i | append: '_role' %}
            
            {% assign testimonial_text = block.settings[testimonial_text_key] %}
            {% assign testimonial_name = block.settings[testimonial_name_key] %}
            {% assign testimonial_role = block.settings[testimonial_role_key] %}
            
            {% if testimonial_text != blank %}
              <div class="ai-premium-conversion__testimonial-{{ ai_gen_id }}">
                <div class="ai-premium-conversion__testimonial-stars-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endfor %}
                </div>
                <p class="ai-premium-conversion__testimonial-text-{{ ai_gen_id }}">"{{ testimonial_text }}"</p>
                <div class="ai-premium-conversion__testimonial-author-{{ ai_gen_id }}">
                  <div class="ai-premium-conversion__testimonial-avatar-{{ ai_gen_id }}">
                    {{ testimonial_name | slice: 0 | upcase }}
                  </div>
                  <div class="ai-premium-conversion__testimonial-info-{{ ai_gen_id }}">
                    <p class="ai-premium-conversion__testimonial-name-{{ ai_gen_id }}">{{ testimonial_name }}</p>
                    {% if testimonial_role != blank %}
                      <p class="ai-premium-conversion__testimonial-role-{{ ai_gen_id }}">{{ testimonial_role }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="ai-premium-conversion__cta-{{ ai_gen_id }}">
      {% if block.settings.cta_text != blank %}
        <p class="ai-premium-conversion__cta-text-{{ ai_gen_id }}">{{ block.settings.cta_text }}</p>
      {% endif %}
      
      <div class="ai-premium-conversion__buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_label != blank %}
          <a
            href="{{ block.settings.primary_button_link }}"
            class="ai-premium-conversion__button-{{ ai_gen_id }} ai-premium-conversion__button--primary-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.primary_button_label }}</span>
            {% if block.settings.show_button_icon %}
              <svg class="ai-premium-conversion__button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            {% endif %}
          </a>
        {% endif %}
        
        {% if block.settings.secondary_button_label != blank %}
          <a
            href="{{ block.settings.secondary_button_link }}"
            class="ai-premium-conversion__button-{{ ai_gen_id }} ai-premium-conversion__button--secondary-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.secondary_button_label }}</span>
          </a>
        {% endif %}
      </div>
      
      {% if block.settings.guarantee_text != blank %}
        <div class="ai-premium-conversion__guarantee-{{ ai_gen_id }}">
          <svg class="ai-premium-conversion__guarantee-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span>{{ block.settings.guarantee_text }}</span>
        </div>
      {% endif %}
    </div>

  </div>
</premium-conversion-{{ ai_gen_id }}>

<script>
(function() {
  class PremiumConversion{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.initObserver();
      this.initButtons();
    }

    initObserver() {
      const options = {
        threshold: 0.1,
        rootMargin: '0px 0px -100px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, options);

      const elements = this.querySelectorAll('[class*="__benefit-"], [class*="__testimonial-"]');
      elements.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
      });
    }

    initButtons() {
      const buttons = this.querySelectorAll('.ai-premium-conversion__button-{{ ai_gen_id }}');
      
      buttons.forEach(button => {
        button.addEventListener('click', function(e) {
          const ripple = this.querySelector('::before');
          this.style.transform = 'scale(0.98)';
          
          setTimeout(() => {
            this.style.transform = '';
          }, 150);
        });

        button.addEventListener('touchstart', function() {
          this.style.transform = 'scale(0.98)';
        });

        button.addEventListener('touchend', function() {
          this.style.transform = '';
        });
      });
    }
  }

  customElements.define('premium-conversion-{{ ai_gen_id }}', PremiumConversion{{ ai_gen_id }});
})();
</script>

