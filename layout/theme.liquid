<!doctype html>
<html lang="{{ request.locale.iso_code | default: 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {{ content_for_header }}
    {{ 'luxense-store.css' | asset_url | stylesheet_tag }}
  </head>

  <body>
    {{ content_for_layout }}
    <script type="module" src="{{ 'luxense-store.js' | asset_url }}" defer></script>
  </body>
</html>
